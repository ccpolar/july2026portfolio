# Copy to `.env` for local dev. On Vercel, set these in Project → Settings →
# Environment Variables instead. Never commit the real .env.

# ── Database ─────────────────────────────────────────────────────────────
# Local dev: leave as the SQLite file (no database to install).
# Production: a Postgres connection string — the app switches adapters on the
# `postgres://` prefix automatically.
DATABASE_URI=file:./portfolio.db
# DATABASE_URI=postgres://user:password@host/dbname?sslmode=require

# ── Payload secret ───────────────────────────────────────────────────────
# Signs auth tokens. Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=change-me-to-a-long-random-string

# ── Public site URL ──────────────────────────────────────────────────────
# Local: http://localhost:3000. Production: your live URL (e.g.
# https://your-site.vercel.app or a custom domain).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Media storage (production only) ──────────────────────────────────────
# Set automatically by Vercel once you connect a Blob store to the project.
# When present, uploads go to Vercel Blob; when absent, they save to the local
# `media/` folder. Leave this unset for local development.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
